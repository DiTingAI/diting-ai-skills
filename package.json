{
  "name": "diting-skills",
  "version": "1.0.2",
  "description": "谛听 AI Skills - 上传本地音频/视频，解析B站链接，创建转写任务，检索知识库，并读取、更新文件内容。",
  "main": "./bin/diting.js",
  "license": "MIT-0",
  "author": "diting",
  "homepage": "https://diting.cc",
  "bin": {
    "diting": "./bin/diting.js"
  },
  "files": [
    "bin",
    "scripts",
    "references",
    "README.md",
    "SKILL.md",
    "_meta.json"
  ],
  "scripts": {
    "cli:help": "node ./bin/diting.js --help",
    "build:binary:host": "node ./scripts/build_binary.js --target host",
    "build:binary:macos-arm64": "node ./scripts/build_binary.js --target node18-macos-arm64 --output dist/diting-macos-arm64",
    "build:binary:macos-x64": "node ./scripts/build_binary.js --target node18-macos-x64 --output dist/diting-macos-x64",
    "build:binary:linux-x64": "node ./scripts/build_binary.js --target node18-linux-x64 --output dist/diting-linux-x64",
    "build:binary:win-x64": "node ./scripts/build_binary.js --target node18-win-x64 --output dist/diting-win-x64.exe",
    "build:binary:all": "npm run build:binary:macos-arm64 && npm run build:binary:macos-x64 && npm run build:binary:linux-x64 && npm run build:binary:win-x64",
    "test": "node __tests__/run-tests.js",
    "release:zip": "node ./scripts/create-release-zip.js",
    "release:verify": "node ./scripts/verify-release.js",
    "release": "npm test && npm run release:zip && npm run release:verify",
    "release:agent": "node ./scripts/create-agent-release.js",
    "release:full": "npm test && npm run release:agent"
  },
  "pkg": {
    "targets": [
      "node18-macos-arm64"
    ],
    "outputPath": "dist"
  },
  "keywords": [
    "diting",
    "transcription",
    "video-to-text",
    "meeting-summary",
    "audio",
    "video",
    "bilibili",
    "cli",
    "openclaw",
    "skill"
  ],
  "clawhub": {
    "acceptLicenseTerms": true
  },
  "openclaw": {
    "minVersion": "0.1.0",
    "baseUrl": "https://api.diting.cc",
    "requires": {},
    "optionalEnv": [
      "DITING_API_KEY"
    ]
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}