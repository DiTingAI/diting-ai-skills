source "https://rubygems.org"

# GitHub Pages 版本兼容性
gem "github-pages", group: :jekyll_plugins

# 主题
gem "jekyll-theme-cayman"

# SEO 插件
gem "jekyll-seo-tag"

# 站点地图插件
gem "jekyll-sitemap"

# Feed 插件
gem "jekyll-feed"

# Markdown 处理
gem "kramdown"

# 语法高亮
gem "rouge"

# 开发依赖
group :development do
  gem "jekyll", "~> 4.3"
  gem "webrick"
end