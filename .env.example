# 谛听 AI Skills 环境变量配置
# 复制此文件为 .env 并填写你的 API Key

# 必填: 在 https://diting.cc/home/apikey 获取 API Key
DITING_API_KEY=sk-diting-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 可选: API 基础 URL (默认为 https://api.diting.cc)
# DITING_API_BASE_URL=https://api.diting.cc

# 可选: 调试模式
# DEBUG=diting:*

# 可选: 请求超时时间 (毫秒)
# DITING_TIMEOUT=30000

# 可选: 重试次数
# DITING_RETRY_COUNT=2

# 可选: 重试延迟 (毫秒)
# DITING_RETRY_DELAY=1000